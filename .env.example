# =============================================================================
# Advanced Crypto Trading Bot - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# =============================================================================

# =============================================================================
# TELEGRAM
# =============================================================================
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram user ID (get from @userinfobot on Telegram)
# Separate multiple admins with commas: 123456789,987654321
ADMIN_IDS=your_telegram_user_id_here

# =============================================================================
# INDODAX API (OPSIONAL)
# =============================================================================
# Kosongkan jika bot HANYA untuk baca market data & signals
# Isi jika bot akan execute trades (buy/sell otomatis)
# Get API keys from Indodax website → Settings → API
# =============================================================================
INDODAX_API_KEY=
INDODAX_SECRET_KEY=

# =============================================================================
# TRADING PAIRS
# =============================================================================
# Format: lowercase, no slashes (e.g., btcidr, ethidr)
# Recommended: Start with 3-6 pairs to avoid rate limiting
WATCH_PAIRS=btcidr,ethidr,bridr,pippinidr,solidr,dogeidr,xrpidr,adaidr

# =============================================================================
# TRADING SETTINGS
# =============================================================================
# Initial balance for simulation (IDR)
INITIAL_BALANCE=10000000

# Stop Loss & Take Profit percentages
STOP_LOSS_PCT=2.0           # Cut Loss: Auto sell jika turun X%
TAKE_PROFIT_PCT=4.0         # Take Profit: Auto sell jika naik X%

# Trade amount limits (IDR)
MIN_TRADE_AMOUNT=100000     # Minimum: 100k IDR
MAX_TRADE_AMOUNT=5000000    # Maximum: 5 juta IDR

# =============================================================================
# AUTO-TRADING CONTROL
# =============================================================================
# false = signals only, true = enable auto-trading
AUTO_TRADING_ENABLED=false

# true = simulation (no real trades), false = real trading
AUTO_TRADE_DRY_RUN=true

# Manual trading commands (/trade)
MANUAL_TRADING_ENABLED=true
CANCEL_TRADE_ENABLED=true

# =============================================================================
# ML MODEL
# =============================================================================
ML_MODEL_PATH=models/trading_model.pkl

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_PATH=data/trading.db

# =============================================================================
# LOGGING
# =============================================================================
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# =============================================================================
# REDIS (OPSIONAL - untuk performance optimization)
# =============================================================================
# Redis akan otomatis dipakai jika tersedia, fallback ke dict jika tidak
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_TTL=300  # Cache TTL in seconds (5 minutes)

# =============================================================================
# NOTES:
# =============================================================================
# 1. DRY RUN MODE (Recommended untuk testing):
#    AUTO_TRADE_DRY_RUN=true → Semua trade disimulasikan
#    Tidak ada uang sungguhan yang digunakan
#
# 2. REAL TRADING MODE:
#    AUTO_TRADE_DRY_RUN=false → Trade sungguhan di Indodax
#    Pastikan API keys sudah diisi
#
# 3. Get your Telegram user ID:
#    - Open Telegram → Search @userinfobot → Start
#    - It will show your numeric user ID
#
# 4. Generate Indodax API keys:
#    - Login to Indodax → Settings → API Key → Create New
#    - Enable "Trade" permission for auto-trading
#    - Copy API Key dan Secret Key ke sini
